# Telegram
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_WEBHOOK_SECRET=     # Random secret string for webhook validation (generate with: openssl rand -hex 32)

# Supabase
SUPABASE_URL=                # https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # Supabase service role key (Settings > API)

# API-Football via RapidAPI
RAPIDAPI_KEY=                # Your RapidAPI key
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# Vercel Cron Security
CRON_SECRET=                 # Random secret for cron endpoint auth (generate with: openssl rand -hex 32)

# Your Vercel deployment domain (set this after first deploy)
VERCEL_URL=                  # e.g. tbet.vercel.app
